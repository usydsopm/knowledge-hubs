function renderDepMap(){
  const W=1080,H=740,bw=300,bh=58;
  const nodes={
    PMGT5205:{x:50,y:60,sub:'or ENGG5205'},
    PMGT5858:{x:50,y:148},
    PMGT5811:{x:50,y:236,sub:'or ENGG5811'},
    PMGT5871:{x:480,y:60},
    PMGT5820:{x:480,y:148},
    PMGT5872:{x:480,y:236},
    PMGT5862:{x:50,y:360},
    PMGT5883:{x:415,y:360},
    PMGT5884:{x:760,y:360},
    PMGT5850:{x:480,y:510},
    PMGT6885:{x:480,y:585},
    PMGT6888:{x:480,y:660},
  };
  const gates={
    g36:{x:50,y:519,w:330,label:'36 cp of Core units',to:'PMGT5850',restrict:'Final semester only (Y2 · S1)'},
    g48:{x:50,y:594,w:330,label:'48 cp · WAM ≥75 · Director approval',to:'PMGT6885',restrict:'Final semester only (Y2 · S1)'},
    g24:{x:50,y:669,w:330,label:'24 cp · WAM ≥65',to:'PMGT6888',restrict:'Semester 2 or 3 only'},
  };
  const edges=[
    ['PMGT5205','PMGT5871'],['PMGT5205','PMGT5820'],['PMGT5205','PMGT5872'],
    ['PMGT5858','PMGT5871'],['PMGT5858','PMGT5820'],['PMGT5858','PMGT5872'],
    ['PMGT5811','PMGT5871'],['PMGT5811','PMGT5820'],['PMGT5811','PMGT5872'],
    ['PMGT5862','PMGT5883'],['PMGT5883','PMGT5884'],
  ];
  function nodeSVG(code){
    const n=nodes[code],u=byCode[code];
    const col=getComputedStyle(document.documentElement).getPropertyValue(COLLECTIONS[u.coll].dot.replace('var(','').replace(')',''))||'#ccc';
    return `<g>
      <rect x="${n.x}" y="${n.y}" width="${bw}" height="${bh}" rx="10" fill="#fff" stroke="#ecd7c8"/>
      <circle cx="${n.x+18}" cy="${n.y+bh/2}" r="6" fill="${col.trim()}" stroke="rgba(65,64,66,.3)"/>
      <text x="${n.x+34}" y="${n.y+23}" font-family="ui-monospace,Menlo,monospace" font-size="13" font-weight="700" fill="#414042">${u.code}</text>
      <text x="${n.x+34}" y="${n.y+41}" font-family="Inter,Arial,sans-serif" font-size="11.5" fill="#8c8587">${u.name.length>34?u.name.slice(0,33)+'…':u.name}</text>
      ${n.sub?`<text x="${n.x+bw-10}" y="${n.y+bh-9}" text-anchor="end" font-family="ui-monospace,monospace" font-size="9.5" fill="#b3a9a2">${n.sub}</text>`:''}
    </g>`;
  }
  function gateSVG(g){
    return `<g>
      <rect x="${g.x}" y="${g.y}" width="${g.w}" height="40" rx="20" fill="#fdf5ef" stroke="#ecd7c8" stroke-dasharray="5 4"/>
      <text x="${g.x+g.w/2}" y="${g.y+25}" text-anchor="middle" font-family="Inter,Arial,sans-serif" font-size="12" font-weight="600" fill="#5f5d5e">${g.label}</text>
    </g>`;
  }
  function restrictSVG(g){
    const b=nodes[g.to],cy=b.y+bh/2;
    return `<g>
      <text x="${b.x+bw+18}" y="${cy-3}" font-family="Inter,Arial,sans-serif" font-size="11.5" font-weight="700" fill="#e64626">⤺ Enrolment restriction</text>
      <text x="${b.x+bw+18}" y="${cy+14}" font-family="Inter,Arial,sans-serif" font-size="12" fill="#5f5d5e">${g.restrict}</text>
    </g>`;
  }
  function edgeSVG(from,to){
    const a=nodes[from],b=nodes[to];
    const x1=a.x+bw,y1=a.y+bh/2,x2=b.x,y2=b.y+bh/2,mx=(x1+x2)/2;
    return `<path d="M${x1},${y1} C${mx},${y1} ${mx},${y2} ${x2},${y2}" fill="none" stroke="#d8b3a3" stroke-width="1.5" marker-end="url(#arr)"/>`;
  }
  function gateEdge(g){
    const a={x:g.x+g.w,y:g.y+20},b=nodes[g.to];
    const x2=b.x,y2=b.y+bh/2,mx=(a.x+x2)/2;
    return `<path d="M${a.x},${a.y} C${mx},${a.y} ${mx},${y2} ${x2},${y2}" fill="none" stroke="#d8b3a3" stroke-width="1.6" marker-end="url(#arr)"/>`;
  }
  // 5862 -> 5884 : exits the same point as 5862 -> 5883, solid, dips below the row
  const skip=(()=>{const a=nodes.PMGT5862,b=nodes.PMGT5884;
    const x1=a.x+bw,y1=a.y+bh/2, x2=b.x+bw/2,y2=b.y+bh;
    return `<path d="M${x1},${y1} C${(x1+x2)/2},${y1+62} ${x2},${y2+44} ${x2},${y2}" fill="none" stroke="#d8b3a3" stroke-width="1.5" marker-end="url(#arr)"/>`;
  })();
  // assumed knowledge note above PMGT5883
  const a5883=`<text x="${nodes.PMGT5883.x+2}" y="${nodes.PMGT5883.y-9}" font-family="Inter,Arial,sans-serif" font-size="10.5" fill="#8c8587">A: ≥80 in PMGT5862 · WAM ≥75 in MPM</text>`;

  const svg=`<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">
    <defs><marker id="arr" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto"><path d="M0,0 L9,4.5 L0,9 Z" fill="#c9794f"/></marker></defs>
    <text x="50" y="30" font-family="Inter,Arial" font-size="12" font-weight="700" letter-spacing="1.5" fill="#e64626">NAMED-UNIT PREREQUISITES</text>
    <line x1="50" y1="465" x2="${W-40}" y2="465" stroke="#ecd7c8"/>
    <text x="50" y="494" font-family="Inter,Arial" font-size="12" font-weight="700" letter-spacing="1.5" fill="#e64626">THRESHOLD GATES · CREDIT POINTS / WAM / PERMISSION</text>
    ${edges.map(e=>edgeSVG(e[0],e[1])).join('')}
    ${skip}
    ${Object.values(gates).map(gateEdge).join('')}
    ${a5883}
    ${Object.keys(nodes).map(nodeSVG).join('')}
    ${Object.values(gates).map(gateSVG).join('')}
    ${Object.values(gates).map(restrictSVG).join('')}
  </svg>`;
  document.getElementById('depMap').innerHTML=svg;
}


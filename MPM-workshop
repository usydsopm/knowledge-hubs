  wrap.querySelectorAll('.uchip').forEach(ch=>ch.onclick=()=>openMove(ch.dataset.code));
  // thesis strip
  document.getElementById('thesisUnits').innerHTML=UNITS.filter(u=>u.coll==='thesis'||u.dual==='research')
    .map(u=>`<span class="uchip" title="${u.name}">${dot(u.coll)}${u.code}</span>`).join('');
  renderMoves();
}
function openMove(code){
  const u=byCode[code],cur=state.moves[code]||{};
  const discs=['technical','leadership','strategic'];
  const discOpts=discs.map(d=>`<option value="${d}" ${(cur.toDisc||COLLECTIONS[u.coll].disc)===d?'selected':''}>${d.charAt(0).toUpperCase()+d.slice(1)}</option>`).join('');
  const stOpts=['core','elective'].map(s=>`<option value="${s}" ${(cur.toStatus||COLLECTIONS[u.coll].status)===s?'selected':''}>${s==='core'?'Core':'Elective'}</option>`).join('');
  const card=document.getElementById('movesCard');
  let ed=document.getElementById('moveEditor'); if(ed)ed.remove();
  ed=document.createElement('div');ed.id='moveEditor';
  ed.style.cssText='border:1px solid var(--line);border-radius:8px;padding:14px;margin-bottom:14px;background:var(--panel-2)';
  ed.innerHTML=`<div style="font-weight:700;margin-bottom:8px">${u.code} · ${u.name}</div>
    <div class="field-row">
      <div class="f"><label>Move to discipline</label><select id="mvDisc">${discOpts}</select></div>
      <div class="f"><label>Move to status</label><select id="mvStatus">${stOpts}</select></div>
    </div>
    <div class="f" style="margin-top:10px"><label>Reason</label><input type="text" id="mvReason" value="${cur.reason||''}" placeholder="Why should it move?"></div>
    <div style="margin-top:12px;display:flex;gap:8px">
      <button class="btn" id="mvSave">Save move</button>
      <button class="btn ghost" id="mvCancel">Cancel</button>
      ${state.moves[code]?'<button class="btn ghost" id="mvClear" style="color:var(--remove);border-color:var(--remove)">Remove proposal</button>':''}
    </div>`;
  card.insertBefore(ed,card.querySelector('#movesList'));
  document.getElementById('mvCancel').onclick=()=>ed.remove();
  document.getElementById('mvSave').onclick=()=>{
    const td=document.getElementById('mvDisc').value,ts=document.getElementById('mvStatus').value;
    if(td===COLLECTIONS[u.coll].disc&&ts===COLLECTIONS[u.coll].status){delete state.moves[code];}
    else state.moves[code]={toDisc:td,toStatus:ts,reason:document.getElementById('mvReason').value};
    ed.remove();markDirty();renderMatrix();
  };
  const clr=document.getElementById('mvClear');
  if(clr)clr.onclick=()=>{delete state.moves[code];ed.remove();markDirty();renderMatrix();};
}
function renderMoves(){
  const box=document.getElementById('movesList');
  const codes=Object.keys(state.moves);
  if(!codes.length){box.innerHTML='<div class="empty">No moves proposed yet. Click a unit chip above.</div>';return;}
  box.innerHTML=codes.map(c=>{const u=byCode[c],m=state.moves[c];
    return `<div class="mitem"><div class="body"><div class="src">${u.code} · ${u.name}</div>
      <div class="into">${cap(COLLECTIONS[u.coll].disc)}/${COLLECTIONS[u.coll].status} → ${cap(m.toDisc)}/${m.toStatus}</div>
      ${m.reason?`<div class="rat">${m.reason}</div>`:''}</div><button class="del" data-c="${c}">×</button></div>`;}).join('');
  box.querySelectorAll('.del').forEach(b=>b.onclick=()=>{delete state.moves[b.dataset.c];markDirty();renderMatrix();});
}
const cap=s=>s.charAt(0).toUpperCase()+s.slice(1);


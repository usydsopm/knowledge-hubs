<!DOCTYPE html>
<html lang="en-AU">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MPM Curriculum Review — Workshop</title>
<style>
  :root{
    --ochre:#e64626;
    --ochre-soft:#f3dccf;
    --ochre-tint:#fbe3d8;
    --charcoal:#414042;
    --cream:#fcede2;

    --ink:#414042;
    --ink-soft:#5f5d5e;
    --muted:#8c8587;
    --line:#ecd7c8;
    --line-soft:#f4e4d8;
    --paper:#fcede2;
    --panel:#ffffff;
    --panel-2:#fdf5ef;

    /* decision semantics */
    --keep:#2f7d5b;
    --remove:#a02c2c;
    --modify:#bf8a2c;
    --discuss:#6c6a6b;

    /* collection dot colours — green=technical, blue=leadership, orange=strategic; pastel = elective */
    --d-core-tech:#adf3ab;
    --d-elec-tech:#dafdcc;
    --d-core-lead:#72d3fa;
    --d-elec-lead:#d4f6ff;
    --d-core-strat:#fa8b39;
    --d-elec-strat:#fbca10;
    --d-thesis:#a2d9c7;

    --radius:11px;
    --shadow:0 1px 2px rgba(65,64,66,.05), 0 10px 26px rgba(65,64,66,.07);
    --mono:ui-monospace,"SF Mono",Menlo,Consolas,monospace;
    --sans:"Inter","Helvetica Neue",Helvetica,Arial,system-ui,sans-serif;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{font-family:var(--sans);color:var(--ink);background:var(--paper);-webkit-font-smoothing:antialiased;line-height:1.5}
  button{font-family:inherit}

  .app{display:grid;grid-template-columns:272px 1fr;min-height:100vh}

  /* ---------- rail ---------- */
  .rail{background:var(--charcoal);color:#cfc8c2;padding:24px 18px 28px;position:sticky;top:0;height:100vh;overflow-y:auto}
  .brand{margin-bottom:24px}
  .brand .kicker{font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--ochre);font-weight:700}
  .brand .title{font-size:18px;font-weight:700;color:#fff;letter-spacing:-.01em;line-height:1.18;margin-top:3px}
  .brand .sub{font-size:12px;color:#9b938d;margin-top:5px}
  nav{display:flex;flex-direction:column;gap:2px}
  .nav-item{display:grid;grid-template-columns:24px 1fr;align-items:center;gap:9px;width:100%;text-align:left;border:0;background:transparent;color:#b6aea8;padding:11px 10px;border-radius:8px;cursor:pointer;transition:background .12s,color .12s}
  .nav-item .n{font-family:var(--mono);font-size:11px;color:#857c76;font-weight:600}
  .nav-item .t{font-weight:600;font-size:13.5px;line-height:1.25}
  .nav-item .d{font-size:11.5px;color:#897f79;margin-top:4px}
  .nav-item:hover{background:#4d4c4e;color:#efe9e4}
  .nav-item.active{background:var(--ochre);color:#fff}
  .nav-item.active .n,.nav-item.active .d{color:#ffd9cd}
  .rail-foot{margin-top:24px;padding-top:18px;border-top:1px solid #545254}
  .tally{background:#4a4849;border-radius:9px;padding:12px 14px;margin-bottom:12px}
  .tally .lab{font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;color:#a39a94;font-weight:700}
  .tally .num{font-size:24px;font-weight:700;color:#fff;font-family:var(--mono)}
  .tally .num small{font-size:13px;color:#a39a94;font-weight:500}
  .btn-export{width:100%;border:0;background:var(--ochre);color:#fff;font-weight:700;font-size:13px;padding:11px;border-radius:8px;cursor:pointer;transition:filter .12s}
  .btn-export:hover{filter:brightness(1.07)}

  /* ---------- main ---------- */
  .topbar{position:sticky;top:0;z-index:5;background:rgba(252,237,226,.86);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);padding:14px 40px;display:flex;align-items:center;justify-content:space-between;gap:18px}
  .crumb{font-size:12px;color:var(--muted);font-family:var(--mono)}
  .progress{display:flex;gap:5px}
  .progress .seg{width:26px;height:5px;border-radius:3px;background:var(--line)}
  .progress .seg.done{background:var(--charcoal)}
  .progress .seg.cur{background:var(--ochre)}

  .view{padding:34px 40px 90px;max-width:1120px}
  .view[hidden]{display:none}
  .eyebrow{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--ochre);font-weight:700;margin-bottom:9px;display:flex;align-items:center;gap:9px}
  .eyebrow .seq{font-family:var(--mono);color:var(--muted)}
  h1.page{font-size:30px;font-weight:700;letter-spacing:-.02em;margin:0 0 8px;line-height:1.12}
  .lede{font-size:15.5px;color:var(--ink-soft);max-width:700px;margin:0 0 26px}

  .card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:22px 24px;margin-bottom:18px}

  .code{font-family:var(--mono);font-size:12.5px;font-weight:600;color:var(--ink-soft)}
  .hcode{font-family:var(--mono);font-weight:700;color:var(--ink)}
  .multidisc{display:inline-flex;align-items:center;gap:7px;font-size:11.5px;font-weight:700;color:var(--ink);background:var(--ochre-tint);border:1px solid var(--ochre-soft);border-radius:999px;padding:4px 11px}
  .multidisc .dots{display:inline-flex;gap:3px}
  .commentbox{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:16px 20px;margin-bottom:18px}
  .commentbox label{display:block;font-size:11px;letter-spacing:.06em;text-transform:uppercase;font-weight:700;color:var(--ink-soft);margin-bottom:8px}
  .commentbox textarea{min-height:62px}
  .mxnote{font-size:12px;color:var(--muted);margin-top:10px;font-style:italic}

  /* dot + chip */
  .dot{display:inline-block;width:11px;height:11px;border-radius:50%;border:1px solid rgba(65,64,66,.28);flex:none}
  .chip{display:inline-flex;align-items:center;gap:7px;font-size:12px;font-weight:600;padding:4px 10px;border-radius:999px;white-space:nowrap;background:var(--panel-2);border:1px solid var(--line);color:var(--ink)}
  .chip.elective{border-style:dashed;color:var(--ink-soft)}

  /* ---------- overview ---------- */
  .obj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px}
  .obj{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:18px 18px 20px;position:relative;overflow:hidden}
  .obj::before{content:"";position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--ochre)}
  .obj .t{font-weight:700;font-size:15px;margin:0 0 6px}
  .obj p{margin:0;font-size:13.5px;color:var(--muted)}
  .agenda-list{list-style:none;margin:0;padding:0}
  .agenda-list li{display:grid;grid-template-columns:34px 1fr auto;align-items:center;gap:14px;padding:14px 4px;border-bottom:1px solid var(--line-soft)}
  .agenda-list li:last-child{border-bottom:0}
  .agenda-list .ix{font-family:var(--mono);font-size:13px;color:var(--ochre);font-weight:700}
  .agenda-list .nm{font-weight:600;font-size:14.5px}
  .agenda-list .ds{font-size:12.5px;color:var(--muted);margin-top:4px}
  .agenda-list .go{border:1px solid var(--line);background:var(--panel);border-radius:7px;padding:6px 12px;font-size:12.5px;cursor:pointer;color:var(--ink-soft);font-weight:600}
  .agenda-list .go:hover{border-color:var(--ochre);color:var(--ochre)}

  .factbar{display:flex;gap:24px;flex-wrap:wrap;background:var(--panel-2);border:1px solid var(--line);border-radius:var(--radius);padding:16px 20px;margin-bottom:22px}
  .factbar .f{display:flex;flex-direction:column}
  .factbar .v{font-size:21px;font-weight:700;font-family:var(--mono);color:var(--ochre)}
  .factbar .k{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);font-weight:600;margin-top:2px}

  /* ---------- legend ---------- */
  .legend{display:flex;flex-wrap:wrap;gap:10px 18px;padding:14px 18px;background:var(--panel-2);border:1px solid var(--line);border-radius:10px;margin-bottom:18px}
  .legend .li{display:flex;align-items:center;gap:7px;font-size:12.5px;font-weight:600;color:var(--ink-soft)}

  /* ---------- structure / pathways ---------- */
  .pathways{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:8px}
  .pathway{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}
  .pathway h4{margin:0;padding:13px 18px;font-size:14px;background:var(--charcoal);color:#fff;display:flex;align-items:center;gap:9px}
  .pathway h4 .badge{font-size:10.5px;font-weight:700;background:var(--ochre);color:#fff;padding:2px 8px;border-radius:999px;letter-spacing:.04em}
  .sem{padding:13px 16px;border-top:1px solid var(--line-soft)}
  .sem .sl{font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:9px}
  .sem .units{display:flex;flex-wrap:wrap;gap:7px}
  .pchip{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11.5px;font-weight:600;padding:5px 9px;border-radius:7px;border:1px solid var(--line);background:var(--panel-2)}
  .pchip.elec{border-style:dashed;color:var(--muted);font-family:var(--sans);font-weight:600}

  /* available electives (structure §c) */
  .elec-cols{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  .elec-col .ec-head{font-size:12.5px;font-weight:700;display:flex;align-items:center;gap:7px;padding-bottom:9px;margin-bottom:6px;border-bottom:1px solid var(--line)}
  .ec-n{margin-left:auto;font-family:var(--mono);color:var(--muted);font-weight:600}
  .aunit{font-size:13px;padding:5px 0;color:var(--ink-soft);display:flex;gap:8px;align-items:baseline;flex-wrap:wrap}
  .aunit .dot{align-self:center}
  .aunit .hcode{flex:none}
  .aunit .ast{color:var(--ochre);font-weight:700}
  .aunit .flagnote{font-size:9px;padding:1px 6px;white-space:nowrap;font-weight:700}
  .ag-cell .aunit{flex-wrap:nowrap}
  .elec-thesis{margin-top:16px;padding-top:13px;border-top:1px solid var(--line-soft);font-size:12.5px;color:var(--muted);display:flex;gap:7px;align-items:center;flex-wrap:wrap}
  .elec-thesis .dot{flex:none}

  /* unit availability */
  .avail-core-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px 26px}
  .acore{display:flex;align-items:center;gap:9px;font-size:13.5px;color:var(--ink-soft);padding:7px 0;border-bottom:1px solid var(--line-soft)}
  .acore .acore-n{flex:1}
  .availctrl{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:16px 20px}
  .ac-q{font-size:13.5px;font-weight:700;color:var(--ink);margin-bottom:11px}
  .avtog{max-width:400px;margin-bottom:11px}
  .avtog button.on.keep{background:var(--keep);border-color:var(--keep);color:#fff}
  .avtog button.on.change{background:var(--modify);border-color:var(--modify);color:#fff}
  .avail-grid{display:grid;grid-template-columns:1fr 1fr;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;background:var(--panel);box-shadow:var(--shadow)}
  .ag-head{background:var(--charcoal);color:#fff;font-weight:700;font-size:13px;padding:11px 16px}
  .ag-head.col2{border-left:1px solid #54525a}
  .ag-cell{padding:12px 16px;border-top:1px solid var(--line);display:flex;flex-direction:column;gap:2px}
  .ag-cell.col2{border-left:1px solid var(--line)}
  .ag-both{grid-column:1 / -1;border-top:1px solid var(--line);padding:13px 16px;background:var(--panel-2)}
  .agb-head{font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:9px}
  .agb-units{display:grid;grid-template-columns:1fr 1fr;gap:4px 26px}

  .svgwrap{width:100%;overflow-x:auto}
  .svgwrap svg{width:100%;min-width:760px;height:auto;display:block}
  .degmap-card{padding:6px;margin-left:-16px;margin-right:-16px}
  .degmap{overflow-x:auto;background:#fff;border-radius:8px}
  .degmap svg{display:block;width:100%;height:auto;min-width:1040px}

  /* award requirements */
  .award-h{font-size:14px;font-weight:700;color:var(--ochre);margin-bottom:9px}
  .award p{font-size:13.5px;color:var(--ink-soft);margin:0 0 8px}
  .award ul{margin:0;padding-left:20px}
  .award li{font-size:13px;color:var(--ink-soft);margin:3px 0}
  .award-cols{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:12px;padding-top:13px;border-top:1px solid var(--line-soft)}
  .award-sub{font-size:12px;font-weight:700;color:var(--ink);margin-bottom:5px}

  /* elective semester circle + tight rows */
  .semcirc{display:inline-flex;align-items:center;justify-content:center;min-width:22px;height:22px;border-radius:11px;padding:0 6px;font-size:8.5px;font-weight:700;color:var(--keep);background:#e6f1ec;border:1px solid #cfe5db;white-space:nowrap;flex:none;margin-left:auto}
  .elec-col .aunit{flex-wrap:nowrap;align-items:center}
  .elec-col .aunit .anm{flex:1;min-width:0}
  .aunit.tight,.aunit.tight .hcode{font-size:9.5px}
  .aunit.tight .anm{white-space:nowrap}
  .aunit.tight .semcirc{font-size:7px;min-width:17px;height:17px;padding:0 4px}

  /* ---------- unit cards (prereq) ---------- */
  .group{margin-bottom:30px}
  .group-head{display:flex;align-items:center;gap:12px;margin:0 0 13px;flex-wrap:wrap}
  .group-head .gt{font-size:13px;font-weight:700}
  .group-head .req{font-family:var(--mono);font-size:11.5px;color:var(--ink-soft);background:var(--ochre-tint);border:1px solid var(--ochre-soft);border-radius:6px;padding:4px 9px;max-width:620px}
  .group-head .rule{flex:1;height:1px;background:var(--line);min-width:20px}
  .group-head .cnt{font-size:12px;color:var(--muted)}

  .ucard{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:16px;overflow:hidden}
  .ucard.decided-keep{border-left:4px solid var(--keep)}
  .ucard.decided-remove{border-left:4px solid var(--remove)}
  .ucard.decided-modify{border-left:4px solid var(--modify)}
  .ucard.decided-discuss{border-left:4px solid var(--discuss)}
  .ucard-top{padding:18px 22px 8px}
  .ucard h3{margin:0 0 4px;font-size:17px;font-weight:700;display:flex;align-items:center;gap:9px}
  .ucard .ucode{margin-bottom:9px}
  .ucard .tags{display:flex;gap:7px;flex-wrap:wrap;align-items:center}
  .flagnote{font-size:12px;color:var(--remove);background:#f7e7e3;border:1px solid #eccac2;border-radius:6px;padding:3px 9px;font-weight:600}

  /* prereq group cards */
  .group-tag{display:inline-block;background:var(--ochre);color:#fff;font-size:13px;font-weight:700;padding:3px 13px;border-radius:7px;letter-spacing:.02em}
  .group-reqline{margin-top:10px}
  .group-reqline .req{font-family:var(--mono);font-size:11.5px;color:var(--ink-soft);background:var(--ochre-tint);border:1px solid var(--ochre-soft);border-radius:6px;padding:5px 10px;display:inline-block;line-height:1.5}
  .gunits{border-top:1px solid var(--line-soft);margin-top:14px}
  .gunit{padding:14px 22px;border-bottom:1px solid var(--line-soft)}
  .gunit-h{font-size:15px;font-weight:600;display:flex;align-items:center;gap:9px;flex-wrap:wrap}
  .gunit-meta{display:flex;gap:22px;flex-wrap:wrap;font-size:12.5px;color:var(--muted);margin:7px 0 10px}
  .gunit-meta b{color:var(--ink-soft);font-weight:700}
  .gunit .dep{margin:0;border-radius:8px;border:1px solid var(--line-soft);border-bottom:1px solid var(--line-soft)}

  .meta{display:grid;grid-template-columns:repeat(2,1fr);border-top:1px solid var(--line-soft);border-bottom:1px solid var(--line-soft);margin-top:12px}
  .meta .m{padding:11px 22px;border-right:1px solid var(--line-soft)}
  .meta .m:nth-child(2n){border-right:0}
  .meta .ml{font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:4px}
  .meta .mv{font-size:13.5px;font-weight:600}
  .track{display:flex;gap:5px;margin-top:7px}
  .track .slot{flex:1;text-align:center;font-family:var(--mono);font-size:10px;font-weight:600;padding:5px 0;border-radius:5px;background:var(--panel-2);color:#b3a9a2;border:1px solid var(--line-soft)}
  .track .slot.taken{background:var(--ochre-tint);color:var(--ochre);border-color:var(--ochre-soft)}
  .track .slot.open{background:#fff;color:var(--ink-soft);border:1px dashed var(--ochre-soft)}
  .flexnote{font-size:11.5px;color:var(--muted);margin-top:7px;font-style:italic}
  .offered-pills{display:flex;gap:5px;margin-top:6px}
  .offered-pills .op{font-family:var(--mono);font-size:11px;font-weight:600;color:var(--keep);background:#e6f1ec;border:1px solid #cfe5db;border-radius:5px;padding:2px 8px}
  .offered-pills .op.none{color:var(--muted);background:var(--panel-2);border-color:var(--line)}

  .dep{display:flex;align-items:center;gap:9px;flex-wrap:wrap;padding:14px 22px;background:var(--panel-2);border-bottom:1px solid var(--line-soft)}
  .dep .node{font-family:var(--mono);font-size:11.5px;font-weight:600;padding:5px 11px;border-radius:7px;background:#fff;border:1px solid var(--line)}
  .dep .node.pre{border-style:dashed;color:var(--ink-soft)}
  .dep .node.self{border-color:var(--ochre);background:var(--ochre-tint);color:var(--ochre)}
  .dep .gate{font-family:var(--sans);font-size:11.5px;font-weight:600;color:var(--ink-soft);background:#fff;border:1px dashed var(--line);border-radius:7px;padding:5px 11px}
  .dep .arrow{color:var(--ochre);font-size:15px;font-weight:700}

  .decide{padding:18px 22px 20px}
  .lenses{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px}
  .lens label{display:block;font-size:11px;letter-spacing:.05em;text-transform:uppercase;font-weight:700;color:var(--ink-soft);margin-bottom:5px}
  .lens .hint{font-size:11px;color:var(--muted);font-weight:400;text-transform:none;letter-spacing:0}
  textarea,input[type=text],select{width:100%;border:1px solid var(--line);border-radius:8px;padding:9px 11px;font-size:13px;font-family:inherit;color:var(--ink);background:var(--panel-2);resize:vertical;line-height:1.45}
  textarea:focus,input[type=text]:focus,select:focus{outline:2px solid var(--ochre);outline-offset:-1px;background:#fff}
  .lens textarea{min-height:72px}
  .verdict{display:flex;align-items:center;gap:9px;flex-wrap:wrap}
  .verdict .vlab{font-size:11px;letter-spacing:.07em;text-transform:uppercase;font-weight:700;color:var(--muted);margin-right:4px}
  .vbtn{border:1.5px solid var(--line);background:var(--panel);border-radius:999px;padding:7px 15px;font-size:13px;font-weight:600;cursor:pointer;color:var(--ink-soft);transition:all .12s}
  .vbtn:hover{border-color:var(--ink-soft)}
  .vbtn[data-v=keep].on{background:var(--keep);border-color:var(--keep);color:#fff}
  .vbtn[data-v=remove].on{background:var(--remove);border-color:var(--remove);color:#fff}
  .vbtn[data-v=modify].on{background:var(--modify);border-color:var(--modify);color:#fff}
  .vbtn[data-v=discuss].on{background:var(--discuss);border-color:var(--discuss);color:#fff}

  /* ---------- no-prereq grid ---------- */
  .grid2{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}
  .npc{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px 18px;box-shadow:var(--shadow)}
  .npc.flagged{border-left:4px solid var(--modify)}
  .npc.confirmed{border-left:4px solid var(--keep)}
  .npc h4{margin:0 0 3px;font-size:15px;display:flex;align-items:center;gap:8px}
  .npc .row{display:flex;gap:7px;margin:8px 0 12px;flex-wrap:wrap;align-items:center}
  .npc-meta{display:flex;gap:22px;flex-wrap:wrap;margin:2px 0 14px}
  .npc-meta .nmi{flex:1;min-width:150px}
  .npc-meta .nm-l{font-size:10px;letter-spacing:.09em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:5px}
  .toggle2{display:flex;gap:7px;margin-bottom:10px}
  .toggle2 button{flex:1;border:1.5px solid var(--line);background:var(--panel);border-radius:8px;padding:8px;font-size:12.5px;font-weight:600;cursor:pointer;color:var(--ink-soft)}
  .toggle2 button.on.ok{background:var(--keep);border-color:var(--keep);color:#fff}
  .toggle2 button.on.flag{background:var(--modify);border-color:var(--modify);color:#fff}

  /* ---------- matrix ---------- */
  .matrix{display:grid;grid-template-columns:130px 1fr 1fr;border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;background:var(--panel);box-shadow:var(--shadow)}
  .matrix .mh{background:var(--charcoal);color:#fff;font-weight:700;font-size:13px;padding:13px 16px}
  .matrix .mh.corner{background:#54525a;font-size:11.5px;font-weight:600}
  .matrix .rl{display:flex;align-items:center;gap:8px;font-weight:700;font-size:13px;padding:14px;border-top:1px solid var(--line);background:var(--panel-2)}
  .matrix .cell{border-top:1px solid var(--line);border-left:1px solid var(--line);padding:13px;min-height:92px;display:flex;flex-wrap:wrap;gap:7px;align-content:flex-start}
  .uchip{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11.5px;font-weight:600;padding:5px 9px;border-radius:7px;border:1px solid var(--line);background:#fff;cursor:pointer;transition:transform .08s,box-shadow .08s}
  .uchip:hover{transform:translateY(-1px);box-shadow:0 3px 9px rgba(65,64,66,.14)}
  .uchip.moving{border-style:dashed;opacity:.5}
  .ghost{border:1px dashed var(--ochre);background:var(--ochre-tint);color:var(--ochre);font-family:var(--mono);font-size:11px;font-weight:600;padding:5px 9px;border-radius:7px;display:inline-flex;align-items:center;gap:6px}
  .thesis-strip{margin-top:14px;background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:16px 18px;box-shadow:var(--shadow)}
  .thesis-strip .units{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}

  /* ---------- rationalise ---------- */
  .counter{display:flex;align-items:center;gap:22px}
  .counter .stat{display:flex;flex-direction:column}
  .counter .stat .v{font-size:34px;font-weight:700;font-family:var(--mono);line-height:1}
  .counter .stat .k{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-top:5px}
  .counter .arrow{font-size:24px;color:var(--ochre)}
  .counter .delta{font-weight:700;font-size:14px;color:var(--keep)}
  .prompts{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:9px}
  .prompts li{display:flex;gap:9px;font-size:13px;color:var(--ink-soft);padding:9px 12px;background:var(--panel-2);border:1px solid var(--line-soft);border-radius:8px}
  .prompts li::before{content:"›";color:var(--ochre);font-weight:700}
  .merge-pick{display:flex;flex-wrap:wrap;gap:8px;margin:14px 0 16px}
  .pick{font-family:var(--mono);font-size:11.5px;font-weight:600;padding:6px 10px;border-radius:7px;border:1.5px solid var(--line);background:var(--panel);cursor:pointer;color:var(--ink-soft);display:inline-flex;gap:7px;align-items:center}
  .pick.sel{border-color:var(--ochre);background:var(--ochre-tint);color:var(--ochre)}
  .merge-list{margin-top:8px}
  .mitem{display:flex;gap:12px;align-items:flex-start;padding:13px 15px;border:1px solid var(--line);border-radius:8px;margin-bottom:9px;background:var(--panel-2)}
  .mitem .body{flex:1}
  .mitem .src{font-family:var(--mono);font-size:12px;color:var(--ink-soft);margin-bottom:4px}
  .mitem .into{font-weight:700;font-size:14px}
  .mitem .rat{font-size:12.5px;color:var(--muted);margin-top:3px}
  .mitem .del{border:0;background:transparent;color:var(--remove);cursor:pointer;font-size:18px;line-height:1;padding:2px 6px}

  .btn{border:1px solid var(--charcoal);background:var(--charcoal);color:#fff;border-radius:8px;padding:9px 16px;font-size:13px;font-weight:600;cursor:pointer;transition:filter .12s}
  .btn:hover{filter:brightness(1.25)}
  .btn.ghost{background:transparent;color:var(--charcoal);border-color:var(--line)}
  .btn.ghost:hover{filter:none;border-color:var(--charcoal)}
  .btn:disabled{opacity:.4;cursor:not-allowed}
  .field-row{display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap}
  .field-row .f{flex:1;min-width:180px}
  .field-row label{display:block;font-size:11px;letter-spacing:.05em;text-transform:uppercase;font-weight:700;color:var(--ink-soft);margin-bottom:5px}

  .empty{color:var(--muted);font-size:13px;font-style:italic;padding:8px 0}

  /* summary */
  .sum-sec{margin-bottom:26px}
  .sum-sec h3{font-size:13px;letter-spacing:.04em;text-transform:uppercase;color:var(--muted);margin:0 0 12px;font-weight:700}
  .sum-row{display:grid;grid-template-columns:150px 110px 1fr;gap:14px;padding:11px 0;border-bottom:1px solid var(--line-soft);align-items:start}
  .sum-row .u{font-family:var(--mono);font-size:13px;font-weight:600}
  .sum-row .n{font-size:13px;color:var(--ink-soft);font-weight:600}
  .verdict-tag{font-size:11px;font-weight:700;padding:3px 9px;border-radius:999px;text-align:center;white-space:nowrap}
  .verdict-tag.keep{background:#e6f1ec;color:var(--keep)}
  .verdict-tag.remove{background:#f7e7e3;color:var(--remove)}
  .verdict-tag.modify{background:#f7eed8;color:var(--modify)}
  .verdict-tag.discuss{background:#edebec;color:var(--discuss)}
  .verdict-tag.none{background:#f1efef;color:#a39a94}
  .sum-row .notes{font-size:12.5px;color:var(--muted)}

  @media (max-width:900px){
    .app{grid-template-columns:1fr}
    .rail{position:static;height:auto}
    .obj-grid,.lenses,.grid2,.prompts,.pathways,.elec-cols,.avail-core-grid,.agb-units,.award-cols{grid-template-columns:1fr}
    .matrix{grid-template-columns:96px 1fr 1fr}
    .view,.topbar{padding-left:20px;padding-right:20px}
  }
  @media (prefers-reduced-motion:reduce){*{transition:none!important}}
</style>
</head>

function renderRationalise(){
  const pick=document.getElementById('mergePick');
  pick.innerHTML=UNITS.map(u=>`<button class="pick ${state.pick.has(u.code)?'sel':''}" data-c="${u.code}">${dot(u.coll)}${u.code}</button>`).join('');
  pick.querySelectorAll('.pick').forEach(b=>b.onclick=()=>{
    const c=b.dataset.c;state.pick.has(c)?state.pick.delete(c):state.pick.add(c);
    b.classList.toggle('sel');document.getElementById('mergeAdd').disabled=state.pick.size<2;
  });
  document.getElementById('mergeAdd').disabled=state.pick.size<2;
  document.getElementById('mergeAdd').onclick=()=>{
    state.merges.push({id:Date.now(),codes:[...state.pick],name:document.getElementById('mergeName').value.trim()||'(unnamed merged unit)',rationale:document.getElementById('mergeRat').value.trim()});
    state.pick.clear();document.getElementById('mergeName').value='';document.getElementById('mergeRat').value='';
    markDirty();renderRationalise();renderMergeList();updateCounter();
  };
  renderMergeList();updateCounter();
}
function renderMergeList(){
  const box=document.getElementById('mergeList');
  if(!state.merges.length){box.innerHTML='<div class="empty">No merges proposed yet.</div>';return;}
  box.innerHTML=state.merges.map(m=>`<div class="mitem"><div class="body"><div class="src">${m.codes.join(' + ')}</div><div class="into">→ ${m.name}</div>${m.rationale?`<div class="rat">${m.rationale}</div>`:''}</div><button class="del" data-id="${m.id}">×</button></div>`).join('');
  box.querySelectorAll('.del').forEach(b=>b.onclick=()=>{state.merges=state.merges.filter(x=>x.id!=b.dataset.id);markDirty();renderMergeList();updateCounter();renderRationalise();});
}
function updateCounter(){
  const before=UNITS.length;
  const removed=state.merges.reduce((a,m)=>a+(m.codes.length-1),0);
  document.getElementById('cntBefore').textContent=before;
  document.getElementById('cntAfter').textContent=before-removed;
  document.getElementById('cntDelta').textContent=removed?`−${removed} units`:'';
}

/* ============================================================
   TALLY
   ============================================================ */
function updateTally(){
  let n=0,total=0;
  PREREQ_GROUPS.forEach(g=>{total++;if(state.prereqGroups[g.id]&&state.prereqGroups[g.id].verdict)n++;});
  UNITS.filter(u=>!u.prereqText).forEach(u=>{total++;if(state.noPrereq[u.code]&&state.noPrereq[u.code].status)n++;});
  document.getElementById('tallyNum').textContent=n;
  document.getElementById('tallyTotal').textContent=total;
}

/* ============================================================
   SUMMARY + EXPORT
   ============================================================ */
const VLABEL={keep:'Keep',remove:'Remove',modify:'Modify',discuss:'Discuss'};
function renderSummary(){
  const box=document.getElementById('summary');let h='';
  h+='<div class="sum-sec"><h3>Prerequisite groups</h3>';
  PREREQ_GROUPS.forEach(g=>{
    const s=state.prereqGroups[g.id]||{},v=s.verdict||'none';
    h+=`<div class="sum-row"><span class="u">${g.label}<br><span style="font-family:var(--mono);font-size:11px;color:var(--muted)">${g.units.join(', ')}</span></span><span class="verdict-tag ${v}">${v==='none'?'No decision':VLABEL[v]}</span><span class="notes">${s.comment||'—'}</span></div>`;
  });
  h+='</div><div class="sum-sec"><h3>No-prerequisite units</h3>';
  UNITS.filter(u=>!u.prereqText).forEach(u=>{
    const s=state.noPrereq[u.code]||{};
    const v=s.status==='confirmed'?'keep':s.status==='flagged'?'modify':'none';
    const lab=s.status==='confirmed'?'Confirmed open':s.status==='flagged'?'Flag for prereq':'No decision';
    h+=`<div class="sum-row"><span class="u">${u.code}</span><span class="verdict-tag ${v}">${lab}</span><span class="notes">${s.notes||'—'}</span></div>`;
  });
  h+='</div><div class="sum-sec"><h3>Proposed collection / status moves</h3>';
  const moves=Object.keys(state.moves);
  if(!moves.length)h+='<div class="empty">None.</div>';
  moves.forEach(c=>{const u=byCode[c],m=state.moves[c];h+=`<div class="sum-row"><span class="u">${u.code}</span><span class="n">${cap(m.toDisc)}/${m.toStatus}</span><span class="notes">was ${cap(COLLECTIONS[u.coll].disc)}/${COLLECTIONS[u.coll].status}${m.reason?' — '+m.reason:''}</span></div>`;});
  h+='</div><div class="sum-sec"><h3>Proposed merges</h3>';
  if(!state.merges.length)h+='<div class="empty">None.</div>';
  state.merges.forEach(m=>h+=`<div class="sum-row"><span class="u">${m.codes.join(' + ')}</span><span class="n">merge</span><span class="notes">→ ${m.name}${m.rationale?' — '+m.rationale:''}</span></div>`);
  h+='</div>';
  const av=state.availability;
  const tag=c=>c==='change'?'modify':c==='keep'?'keep':'none';
  const lab=c=>c==='change'?'Propose change':c==='keep'?'No change':'—';
  h+='<div class="sum-sec"><h3>Unit availability</h3>';
  h+=`<div class="sum-row"><span class="u">Core units</span><span class="verdict-tag ${tag(av.core.change)}">${lab(av.core.change)}</span><span class="notes">${av.core.comment||'—'}</span></div>`;
  h+=`<div class="sum-row"><span class="u">Electives</span><span class="verdict-tag ${tag(av.elective.change)}">${lab(av.elective.change)}</span><span class="notes">${av.elective.comment||'—'}</span></div>`;
  h+='</div>';
  h+='<div class="sum-sec"><h3>Notes &amp; comments</h3>';
  h+=`<div class="sum-row"><span class="u">Degree map</span><span class="n"></span><span class="notes">${state.comments.degreeMap||'—'}</span></div>`;
  h+=`<div class="sum-row"><span class="u">Dependency map</span><span class="n"></span><span class="notes">${state.comments.depMap||'—'}</span></div>`;
  h+=`<div class="sum-row"><span class="u">Core vs elective</span><span class="n"></span><span class="notes">${state.matrixNotes||'—'}</span></div>`;
  h+='</div>';
  box.innerHTML=h;
}
function buildExport(){
  const date=new Date().toLocaleString('en-AU');
  let md=`# MPM Curriculum Review — Decisions\n_Exported ${date}_\n\n## Prerequisite groups\n`;
  PREREQ_GROUPS.forEach(g=>{
    const s=state.prereqGroups[g.id]||{};
    md+=`\n### ${g.label} — ${g.units.join(', ')}\n- Prerequisite: ${g.req}\n- Decision: **${s.verdict?VLABEL[s.verdict]:'—'}**\n`;
    if(s.comment)md+=`- Comments: ${s.comment}\n`;
  });
  md+=`\n## No-prerequisite units\n`;
  UNITS.filter(u=>!u.prereqText).forEach(u=>{const s=state.noPrereq[u.code]||{};
    md+=`- **${u.code}** ${u.name}: ${s.status==='confirmed'?'Confirmed open-entry':s.status==='flagged'?'Flagged for prerequisite':'—'}${s.notes?' — '+s.notes:''}\n`;});
  md+=`\n## Proposed collection / status moves\n`;
  const mv=Object.keys(state.moves);
  if(!mv.length)md+=`_None_\n`;
  mv.forEach(c=>{const u=byCode[c],m=state.moves[c];md+=`- **${u.code}**: ${cap(COLLECTIONS[u.coll].disc)}/${COLLECTIONS[u.coll].status} → ${cap(m.toDisc)}/${m.toStatus}${m.reason?' — '+m.reason:''}\n`;});
  md+=`\n## Proposed merges\n`;
  if(!state.merges.length)md+=`_None_\n`;
  state.merges.forEach(m=>md+=`- ${m.codes.join(' + ')} → **${m.name}**${m.rationale?' — '+m.rationale:''}\n`);
  const removed=state.merges.reduce((a,m)=>a+(m.codes.length-1),0);
  md+=`\n**Catalogue size:** ${UNITS.length} → ${UNITS.length-removed} units (−${removed})\n`;
  const av=state.availability;
  const lab=c=>c==='change'?'Propose change':c==='keep'?'No change needed':'—';
  md+=`\n## Unit availability\n`;
  md+=`- Core units: ${lab(av.core.change)}${av.core.comment?' — '+av.core.comment:''}\n`;
  md+=`- Electives: ${lab(av.elective.change)}${av.elective.comment?' — '+av.elective.comment:''}\n`;
  md+=`\n## Notes & comments\n`;
  md+=`- Degree map: ${state.comments.degreeMap||'—'}\n`;
  md+=`- Dependency map: ${state.comments.depMap||'—'}\n`;
  md+=`- Core vs elective: ${state.matrixNotes||'—'}\n`;
  const json=JSON.stringify({exported:date,comments:state.comments,matrixNotes:state.matrixNotes,availability:state.availability,prereqGroups:state.prereqGroups,noPrereq:state.noPrereq,moves:state.moves,merges:state.merges},null,2);
  return {md,json};
}
function download(name,text,type){const b=new Blob([text],{type});const url=URL.createObjectURL(b);const a=document.createElement('a');a.href=url;a.download=name;a.click();setTimeout(()=>URL.revokeObjectURL(url),1000);}
function doExport(){const {md,json}=buildExport();download('mpm-review-decisions.md',md,'text/markdown');setTimeout(()=>download('mpm-review-decisions.json',json,'application/json'),300);dirty=false;}
document.getElementById('exportBtn').onclick=doExport;
document.getElementById('exportBtn2').onclick=doExport;
document.getElementById('resetBtn').onclick=()=>{if(!confirm('Clear all captured decisions?'))return;state.prereqGroups={};state.noPrereq={};state.moves={};state.merges=[];state.pick.clear();state.comments={degreeMap:'',depMap:''};state.matrixNotes='';state.availability={core:{change:'',comment:''},elective:{change:'',comment:''}};dirty=false;renderAll();go(7);};
window.addEventListener('beforeunload',e=>{if(dirty){e.preventDefault();e.returnValue='';}});

/* ============================================================
   init
   ============================================================ */
function bindComments(){
  const d=document.getElementById('cmtDegree'),p=document.getElementById('cmtDep'),mn=document.getElementById('matrixNotes');
  if(d){d.value=state.comments.degreeMap||'';d.oninput=()=>{state.comments.degreeMap=d.value;markDirty();};}
  if(p){p.value=state.comments.depMap||'';p.oninput=()=>{state.comments.depMap=p.value;markDirty();};}
  if(mn){mn.value=state.matrixNotes||'';mn.oninput=()=>{state.matrixNotes=mn.value;markDirty();};}
}
function renderAll(){renderPathways();renderAvailElectives();renderDepMap();renderAvailability();renderPrereq();renderNoPrereq();renderMatrix();renderRationalise();renderSummary();bindComments();updateTally();}
renderAll();go(0);
</script>

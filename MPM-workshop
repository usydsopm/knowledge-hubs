  let html=`<div class="matrix"><div class="mh corner">Discipline ╲ Status</div><div class="mh">Core</div><div class="mh">Elective</div>`;
  rows.forEach(r=>{
    html+=`<div class="rl">${dot(discDot[r])}${r.charAt(0).toUpperCase()+r.slice(1)}</div>`;
    ['core','elective'].forEach(stt=>{
      const cell=UNITS.filter(u=>COLLECTIONS[u.coll].disc===r&&COLLECTIONS[u.coll].status===stt);
      html+=`<div class="cell" data-disc="${r}" data-status="${stt}">`;
      cell.forEach(u=>{const mv=state.moves[u.code];html+=`<span class="uchip ${mv?'moving':''}" data-code="${u.code}" title="${u.name}${u.multiDisc?' — may be classed Technical, Strategic or Leadership':''}">${dot(u.coll)}${u.code}${u.multiDisc?'*':''}</span>`;});
      UNITS.forEach(u=>{const mv=state.moves[u.code];if(mv&&mv.toDisc===r&&mv.toStatus===stt)html+=`<span class="ghost" title="proposed: ${u.name}">⤳ ${u.code}</span>`;});
      html+=`</div>`;
    });
  });
  html+=`</div><div class="mxnote">* PMGT6885 (Project Placement Special Topic) may be classed Technical, Strategic or Leadership depending on the nature of the topic.</div>`;
